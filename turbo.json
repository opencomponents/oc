{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "src/components/oc-client/src/**",
        "src/components/oc-client/_package/**",
        "test/fixtures/components/**/_package/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "test-silent": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "oc-fastify-server-adapter#test": {
      "dependsOn": [
        "build",
        "oc#build"
      ],
      "outputs": []
    },
    "oc-fastify-server-adapter#test-silent": {
      "dependsOn": [
        "build",
        "oc#build"
      ],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "preview": {
      "cache": false
    }
  }
}
