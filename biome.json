{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"packages/oc/**/*",
			"!packages/oc/dist/**/*",
			"!packages/oc/src/components/oc-client/**/*",
			"!packages/oc/test/**/*",
			"!packages/oc/tasks/**/*",
			"packages/oc-azure-sql-metadata-adapter/**/*",
			"!packages/oc-azure-sql-metadata-adapter/dist/**/*",
			"!packages/oc-azure-sql-metadata-adapter/node_modules/**/*",
			"packages/oc-azure-table-metadata-adapter/**/*",
			"!packages/oc-azure-table-metadata-adapter/dist/**/*",
			"!packages/oc-azure-table-metadata-adapter/node_modules/**/*",
			"packages/oc-metadata-adapters-utils/**/*",
			"!packages/oc-metadata-adapters-utils/dist/**/*",
			"!packages/oc-metadata-adapters-utils/node_modules/**/*",
			"packages/oc-client-browser/**/*",
			"!packages/oc-client-browser/dist/**/*",
			"!packages/oc-client-browser/vendor/**/*",
			"!packages/oc-client-browser/node_modules/**/*"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useJsxKeyInIterable": "off"
			},
			"complexity": {
				"useLiteralKeys": "off",
				"noExcessiveNestedTestSuites": "off"
			},
			"style": {
				"noParameterAssign": "off",
				"noNonNullAssertion": "off",
				"useTemplate": "off"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"trailingCommas": "none",
			"indentStyle": "space",
			"quoteStyle": "single"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["packages/oc-client-browser/**/*"],
			"linter": {
				"rules": {
					"performance": {
						"noDelete": "off"
					},
					"style": {
						"useConst": "off",
						"useSingleVarDeclarator": "off"
					},
					"suspicious": {
						"noDoubleEquals": "off",
						"useIterableCallbackReturn": "off"
					}
				}
			}
		}
	]
}
