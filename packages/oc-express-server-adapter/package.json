{
	"name": "oc-express-server-adapter",
	"version": "0.1.0",
	"description": "Express HTTP server adapter for OC",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/opencomponents/oc.git",
		"directory": "packages/oc-express-server-adapter"
	},
	"bugs": {
		"url": "https://github.com/opencomponents/oc/issues"
	},
	"homepage": "https://github.com/opencomponents/oc/tree/master/packages/oc-express-server-adapter#readme",
	"keywords": [
		"oc",
		"opencomponents",
		"express",
		"server",
		"adapter"
	],
	"author": "Matteo Figus",
	"license": "MIT",
	"files": [
		"dist",
		"!dist/test/**"
	],
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "npm run lint && tsc",
		"lint": "npx @biomejs/biome check src test",
		"lint:apply": "npx @biomejs/biome check --write src test",
		"test": "jest --runInBand",
		"test-silent": "jest --runInBand --silent"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"testPathIgnorePatterns": [
			"/dist/"
		]
	},
	"dependencies": {
		"cookie-parser": "^1.4.7",
		"errorhandler": "^1.5.2",
		"express": "^5.2.1",
		"morgan": "^1.11.0",
		"multer": "^2.0.2",
		"response-time": "^2.3.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/errorhandler": "^1.5.3",
		"@types/express": "^5.0.6",
		"@types/jest": "^29.5.14",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.9.3",
		"@types/response-time": "^2.3.9",
		"jest": "^29.7.0",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.2.5",
		"typescript": "^6.0.3"
	}
}
