{
	"name": "oc",
	"version": "0.50.58",
	"description": "A framework for developing and distributing html components",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": "./dist/oc-cli.js",
	"scripts": {
		"lint": "npx @biomejs/biome check preview src test tasks",
		"lint:apply": "npx @biomejs/biome check --write preview src test tasks",
		"preview": "bun run preview/uiPreview.ts",
		"prebuild": "rimraf dist",
		"build": "npm run lint && tsc && node tasks/build.js",
		"test": "node tasks/mochaTest.js",
		"test-silent": "node tasks/mochaTest.js --silent",
		"bench": "node tasks/benchmarks/server-benchmark.js --repetitions=5",
		"bench:quick": "node tasks/benchmarks/server-benchmark.js --repetitions=3",
		"bench:update-baseline": "node tasks/benchmarks/server-benchmark.js --repetitions=5 --update-baseline=true",
		"bench:high-load": "node tasks/benchmarks/server-benchmark.js --scenarios=high-load-local,high-load-storage --high-load-repetitions=3"
	},
	"engines": {
		"node": ">=18"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/opencomponents/oc"
	},
	"author": "Matteo Figus",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/opencomponents/oc/issues"
	},
	"homepage": "https://github.com/opencomponents/oc",
	"keywords": [
		"open components",
		"components",
		"oc"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/accept-language-parser": "^1.5.8",
		"@types/async": "^3.2.25",
		"@types/bun": "^1.3.14",
		"@types/cross-spawn": "^6.0.6",
		"@types/express": "^5.0.6",
		"@types/fs-extra": "^11.0.4",
		"@types/livereload": "^0.9.5",
		"@types/node": "^25.9.3",
		"@types/parse-author": "^2.0.3",
		"@types/read": "^0.0.32",
		"@types/semver": "^7.7.1",
		"@types/targz": "^1.0.5",
		"@types/yargs": "^17.0.35",
		"chai": "^6.2.2",
		"chalk": "^4.1.2",
		"glob": "^7.2.3",
		"injectr": "^0.5.1",
		"minimist": "^1.2.8",
		"mocha": "^11.7.6",
		"node-emoji": "^2.2.0",
		"rimraf": "^6.1.3",
		"sinon": "^21.0.0",
		"type-fest": "^2.19.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@kitajs/html": "^4.2.13",
		"@kitajs/ts-html-plugin": "^4.1.4",
		"@rdevis/turbo-stream": "^2.4.1",
		"@types/lodash.isequal": "^4.5.8",
		"accept-language-parser": "^1.5.0",
		"async": "^3.2.6",
		"basic-auth-connect": "^1.1.0",
		"builtin-modules": "^3.3.0",
		"chokidar": "^4.0.3",
		"colors": "^1.4.0",
		"cross-spawn": "^7.0.6",
		"dependency-graph": "^1.0.0",
		"dotenv": "^17.4.2",
		"esbuild": "^0.25.12",
		"express": "^5.2.1",
		"form-data": "^4.0.6",
		"fs-extra": "^11.3.5",
		"getport": "^0.1.0",
		"livereload": "^0.10.3",
		"lodash.isequal": "^4.5.0",
		"nice-cache": "^0.0.5",
		"oc-client": "^4.0.3",
		"oc-client-browser": "^2.1.11",
		"oc-empty-response-handler": "^1.0.2",
		"oc-express-server-adapter": "^0.1.0",
		"oc-get-unix-utc-timestamp": "^1.0.6",
		"oc-metadata-adapters-utils": "^0.1.1",
		"oc-s3-storage-adapter": "^2.2.3",
		"oc-storage-adapters-utils": "^2.1.2",
		"oc-template-es6": "^2.0.0",
		"oc-template-es6-compiler": "^7.1.4",
		"oc-template-handlebars": "^6.0.26",
		"oc-template-handlebars-compiler": "^6.7.1",
		"oc-template-jade": "^7.0.6",
		"oc-template-jade-compiler": "^7.5.0",
		"open": "^10.2.0",
		"parse-author": "^2.0.0",
		"read": "^1.0.7",
		"require-package-name": "^2.0.1",
		"semver": "^7.8.4",
		"semver-extra": "^3.0.0",
		"serialize-error": "^12.0.0",
		"source-map": "^0.7.6",
		"targz": "^1.0.1",
		"try-require": "^1.2.1",
		"undici": "^8.5.0",
		"universalify": "^2.0.1",
		"yargs": "^17.7.2"
	}
}
